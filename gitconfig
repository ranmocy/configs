  email = ranmocy@gmail.com
  signingkey = FC6B5559

[core]
  excludesfile = ~/.gitexclude
  quotePath = false
  editor = git_editor
  mergeoptions = --no-edit
  pager = delta

[alias]
  a = add
  aa = add --all
  b = branch
  bl = for-each-ref --sort=-committerdate --format='%(refname:short)' "refs/heads/*"
  br = for-each-ref --sort=-committerdate --format='%(refname:short)' "refs/remotes/origin/*"
  bb = !echo "===heads===" && git bl && echo "===remotes===" && git br
  bclean = !git checkout main && (git branch --merged | egrep -v '(\\*|main|develop|staging)' | xargs git branch -d) && git checkout -
  bsyncmain = !git checkout main && git pull && git checkout - || true
  bsync = !git f && git bsyncmain && git bclean
  bs = bsync
  d = diff
  ds = diff --staged
  dh = diff HEAD
  df = diff --name-status # per-file summary
  f = fetch -p
  i = commit
  im = commit -m
  iam = commit -am
  iall = !git add --all && git commit
  # l = log --pretty=format:'%C(bold green)%d %C(bold yellow)%h %C(bold red)%an: %Creset%s %C(bold blue)(%ar)' --graph --topo-order
  l = log --pretty=format:'%C(bold green)%d %C(bold yellow)%h %C(bold red)%an: %Creset%s %C(bold blue)(%cd)' --graph --topo-order
  lp = log -p
  ls = log --stat
  lme = log --pretty=format:'%C(bold green)%d %C(bold yellow)%h %C(bold red)%an: %Creset%s %C(bold blue)(%ar)' --author='Ranmocy'
  lyesterday = log --since '1 day ago' --graph --topo-order --pretty=format:'%C(bold green)%d %C(bold yellow)%h %C(bold red)%an: %Creset%s %C(bold blue)(%ar)'
  latest = for-each-ref --sort=-committerdate --format=\"%(committername)@%(refname:short)\t[%(committerdate:short)]\t%(contents)\"
  stat-summary = !git-stat-sum \"$@\"
  o = checkout
  r = remote
  rabort = rebase --abort
  rc = rebase --continue
  s = status -sb
  u = !git checkout main && git pull && git fetch -p
  amend = !sh -c 'git commit --amend -C HEAD --date \"`date`\"'
  amendall = !git add --all && git commit --amend --no-edit
  reset1 = reset HEAD~1
  unamend = reset --soft HEAD@{1}
  uncommit = reset --soft HEAD^
  fixup = "!git log -n 50 --pretty=format:'%h %s' --no-merges | fzf | cut -c -7 | xargs -o git commit --fixup"
  st = stash
  ststaged = stash -S
  stother = stash -uk
  stp = stash pop
  stl = stash list
  stp0 = stash pop stash@{0}
  stp1 = stash pop stash@{1}
  stp2 = stash pop stash@{2}
  stp3 = stash pop stash@{3}
  stp4 = stash pop stash@{4}
  stp5 = stash pop stash@{5}

[branch]
  autosetuprebase = always
  sort = -committerdate

[column]
  ui = auto

[color]
  ui = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection

# [diff]
  # renames = copies
  # mnemonicprefix = true
  # compactionHeuristic = true
  # tool = default-difftool
  # noprefix = true

[difftool "default-difftool"]
  cmd = vim --diff $LOCAL $REMOTE

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[help]
  autocorrect = 1

[init]
  defaultBranch = main

[merge]
  stat = true
  #conflictStyle = zdiff3
[pull]
  rebase = true
[push]
  default = current
  followTags = true
[rebase]
  autosquash = true
[rerere]
  enabled = true

# Network
[http]
  postBuffer = 157286400
  cookiefile = ~/.gitcookies
[fetch]
  writeCommitGraph = true
[credential]
  helper = osxkeychain
[credential "https://github.com"]
  helper = !gh auth git-credential

# Envs
[includeIf "gitdir:~/work/"]
  path = ~/work/.configs/gitconfig
[maintenance]
  repo = ~/.oh-my-configs

