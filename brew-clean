#!/usr/bin/env ruby

WHITELIST = [
  'automake',
  'awscli',
  'basictex',
  'bat',
  'bun',
  'cmake',
  'curl',
  'docker-buildx',
  'docker-compose',
  'docker',
  'eza',
  'fd',
  'fish',
  'fzf',
  'gh',
  'git-delta',
  'go',
  'htop',
  'jq',
  'k9s',
  'kubernetes-cli',
  'ollama',
  'pipx',
  'python',
  'ripgrep',
  'stern',
  'swift-format',
  'swift-test-coverage',
  'watch',
  'wget',
  'yamllint',
  'yt-dlp',
  'zellij',
  'zoxide',
  # cross compile
  # 'aarch64-unknown-linux-gnu',
  # 'x86_64-unknown-linux-gnu',
] + [
  'imessage-exporter',
]

loop {
  to_remove = `brew leaves`
    .split("\n")
    .map { |long_name|
      long_name.split('/').last
    }.delete_if { |name|
      WHITELIST.include?(name)
    }

  if to_remove.empty?
    puts "All cleaned up"
    exit 0
  end

  puts "Confirm to remove:"
  puts to_remove
  puts
  print 'yes|y:'
  unless ['yes', 'y'].include?(gets.chomp)
    puts 'abort'
    exit 1
  end

  to_remove
    .each { |name|
      puts `brew uninstall #{name}`
    }
}
